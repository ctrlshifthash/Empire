# ── Token-holder rewards (Solana) ───────────────────────────────────────────
# Copy this file to server/.env and fill it in. Leave blank to run in DEMO mode
# (no real holdings / no payouts). NEVER commit the real .env.

# Your SPL token mint address. Until set, rewards are in preview/demo mode.
TOKEN_MINT=

# Solana RPC endpoint (use a paid RPC for production reliability).
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Total SOL paid out per day across ALL holders (the shared pool).
DAILY_SOL_POOL=1

# The treasury (payer) wallet's secret key, as the JSON array of 64 numbers
# that `solana-keygen` produces (e.g. [12,34,...]). Until set, claims are
# disabled (preview only). This wallet must be funded with SOL to pay rewards.
TREASURY_SECRET_KEY=

# Privy app secret (server-side verification of wallet ownership — used later).
PRIVY_APP_SECRET=
