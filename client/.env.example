# ── Wallet connect + token config (Vite) ────────────────────────────────────
# Copy this file to client/.env and fill it in. Vite loads it automatically.

# Your Privy App ID (this is PUBLIC — safe to ship in the client bundle).
# When set, the "Connect Wallet" button uses Privy; otherwise it falls back to
# pasting a wallet address.
VITE_PRIVY_APP_ID=

# Your SPL token mint address (same as the server's TOKEN_MINT).
VITE_TOKEN_MINT=

# Solana RPC endpoint.
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com
